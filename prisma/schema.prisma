// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


datasource db {
  provider = "postgresql"
 
}

generator client {
  provider = "prisma-client"
   output   = "../generated/prisma"
}


model Category {
  id        String      @id @default(uuid())
  name      String   @unique
  vendors   Vendor[]
  createdAt DateTime @default(now())
}

model Vendor {
  id            String   @id @default(uuid())

  // Basic Information
  name          String
  businessName  String
  description   String

  // Contact
  email         String
  phone         String
  website       String

  // Location
  address       String
  city          String
  state         String?
  country       String

  latitude      Float?
  longitude     Float?

  // Media
  imageUrl      String?
  galleryUrls   String[]

  // Business Details
  priceRange    String?
  services      String[]

  // Relationship
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}